{
  "imports": {
    "wasmbuild": ""
  },
  "tasks": {
    "build": "deno run --allow-all jsr:@deno/wasmbuild@0.17.3 build --sync",
    "watch": "deno run --watch --allow-all jsr:@deno/wasmbuild@0.17.3 build --sync",
    "start": "deno task build && deno run --allow-net --allow-read jsr:@std/http/file-server --port 8344"
  }
}
