{
  "tasks": {
    "build": "deno run --allow-all jsr:@deno/wasmbuild@0.17.3 build --sync --out ./build/",
    "verify": "deno run --frozen --allow-all jsr:@deno/wasmbuild@0.17.3 build --sync --out ./build/ --check",
    "start": "deno task build && deno run --allow-net --allow-read jsr:@std/http/file-server --host 127.0.0.1 --port 8000"
  }
}
